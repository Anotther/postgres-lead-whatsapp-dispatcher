# App
APP_ENV=local
APP_NAME=postgres-lead-whatsapp-dispatcher
DRY_RUN=true
TIMEZONE=America/Sao_Paulo

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=leads_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=prefer

# Query
LEAD_QUERY_PATH=config/lead_query.example.sql
LEAD_LIMIT=100

# Evolution API / Evolution Go
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=change_me
EVOLUTION_SEND_TEXT_PATH=/message/sendText/{instance}

# Config files
INSTANCES_CONFIG_PATH=config/instances.example.yml
MESSAGES_CONFIG_PATH=config/messages.example.yml

# Dispatch
DEFAULT_COUNTRY_CODE=55
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
STOP_ON_CRITICAL_ERROR=false

# Logs
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=7
LOG_MASK_PHONE=true

# Reports
REPORT_DIR=reports
REPORT_FORMATS=csv,json,md
REPORT_SEND_WHATSAPP=false
REPORT_RECIPIENT_NUMBER=5599999999999
REPORT_RECIPIENT_INSTANCE=caixa-01